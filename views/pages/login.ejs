<%- include('../partials/header') %>

<div class="row min-vh-75 align-items-center">
  <div class="col-12">
    <div class="auth-split-container">
      <div class="row g-0 w-100">
        
        <!-- Left Hero Section (Visuals & Stats) -->
        <div class="col-lg-6 auth-hero-panel d-none d-lg-flex">
          <div>
            <h2 class="text-white fw-extrabold display-6 mb-3">Tackling the E-Waste Crisis</h2>
            <p class="text-white opacity-75 lead">Join our sustainable mission to reuse, reduce, and safely recycle old electronics. Every small step count.</p>
          </div>
          
          <div class="my-5">
            <div class="d-flex align-items-center mb-3">
              <div class="bg-white bg-opacity-10 rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="fas fa-leaf text-success"></i>
              </div>
              <div>
                <h4 class="h6 text-white mb-0">Eco-Friendly Process</h4>
                <p class="small text-white opacity-75 mb-0">Certified urban mining and raw resource extraction.</p>
              </div>
            </div>
            <div class="d-flex align-items-center">
              <div class="bg-white bg-opacity-10 rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                <i class="fas fa-chart-line text-success"></i>
              </div>
              <div>
                <h4 class="h6 text-white mb-0">Track Your Impact</h4>
                <p class="small text-white opacity-75 mb-0">View CO₂ saved and earn points dynamically.</p>
              </div>
            </div>
          </div>
          
          <div class="pt-3 border-top border-white border-opacity-10">
            <span class="small text-white opacity-50">&copy; EcoRecycle India</span>
          </div>
        </div>
        
        <!-- Right Form Section -->
        <div class="col-lg-6 auth-form-panel">
          <div class="auth-card">
            
            <div class="mb-4">
              <h1 class="auth-card-title">Sign In</h1>
              <p class="text-muted">Enter your credentials to access your EcoRecycle account</p>
            </div>
            
            <form action="/login" method="POST" class="needs-validation" novalidate>
              
              <!-- Email Input -->
              <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <div class="input-group-premium">
                  <i class="fas fa-envelope"></i>
                  <input type="email" class="form-control" id="email" name="email" placeholder="name@domain.com" required>
                  <div class="invalid-feedback">
                    Please provide a valid email address.
                  </div>
                </div>
              </div>
              
              <!-- Password Input -->
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center">
                  <label for="password" class="form-label">Password</label>
                  <a href="/forgot-password" class="text-success text-decoration-none small fw-bold">Forgot?</a>
                </div>
                <div class="input-group-premium">
                  <i class="fas fa-lock"></i>
                  <input type="password" class="form-control" id="password" name="password" placeholder="••••••••" required>
                  <button type="button" class="btn-toggle-password" data-target="password" aria-label="Toggle Password Visibility">
                    <i class="fas fa-eye"></i>
                  </button>
                  <div class="invalid-feedback">
                    Please provide your password.
                  </div>
                </div>
              </div>
              
              <!-- Remember Me -->
              <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="rememberMe" name="rememberMe">
                  <label class="form-check-label text-muted small" for="rememberMe">Remember me</label>
                </div>
              </div>
              
              <!-- Sign In Button -->
              <div class="d-grid mb-3">
                <button type="submit" class="btn btn-success py-2">Sign In</button>
              </div>
              
              <!-- Social Sign In divider -->
              <div class="position-relative my-4">
                <hr style="border-color: #cbd5e1;">
                <p class="small text-muted bg-white px-2 position-absolute top-50 start-50 translate-middle">OR</p>
              </div>
              
              <!-- Social logins -->
              <div class="row g-2">
                <div class="col-12">
                  <a href="/auth/google" class="btn btn-outline-light w-100 border d-flex align-items-center justify-content-center py-2 shadow-sm card-hover" style="font-size: 0.9rem; font-weight: 600; border-radius: var(--radius-sm); color: var(--text-color) !important; background-color: var(--card-bg);">
                    <i class="fab fa-google text-danger me-2 fs-5"></i> Continue with Google
                  </a>
                </div>
              </div>
              
              <!-- Register link -->
              <div class="mt-4 text-center">
                <p class="mb-0 text-muted small">Don't have an account? <a href="/register" class="text-success text-decoration-none fw-bold">Register now</a></p>
              </div>
              
            </form>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>