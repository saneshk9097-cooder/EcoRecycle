<%- include('../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">Articles & Insights</h1>
    <p class="text-muted lead">Stay updated with research, policies, and simple steps for sustainable electronic discard.</p>
  </div>
</div>

<!-- Category Filter -->
<div class="row mb-5">
  <div class="col-12 text-center">
    <div class="d-inline-flex flex-wrap justify-content-center gap-2 bg-light border p-2 rounded-pill shadow-sm" style="border-radius: 50rem !important;">
      <button class="btn btn-sm btn-success px-4 rounded-pill active" data-category="all" style="border-radius: 50rem !important;">All</button>
      <button class="btn btn-sm btn-outline-success px-4 rounded-pill border-0" data-category="Education" style="border-radius: 50rem !important;">Education</button>
      <button class="btn btn-sm btn-outline-success px-4 rounded-pill border-0" data-category="How-to" style="border-radius: 50rem !important;">How-to</button>
      <button class="btn btn-sm btn-outline-success px-4 rounded-pill border-0" data-category="Technology" style="border-radius: 50rem !important;">Technology</button>
      <button class="btn btn-sm btn-outline-success px-4 rounded-pill border-0" data-category="Policy" style="border-radius: 50rem !important;">Policy</button>
      <button class="btn btn-sm btn-outline-success px-4 rounded-pill border-0" data-category="Social Impact" style="border-radius: 50rem !important;">Social Impact</button>
    </div>
  </div>
</div>

<!-- Articles Grid -->
<div class="row g-4 mb-5">
  <% articles.forEach(article => { %>
    <div class="col-md-6 col-lg-4 article-card fade-in" data-category="<%= article.category %>">
      <div class="card h-100 border-0 shadow-sm card-hover">
        <img src="<%= article.image %>" class="article-grid-img card-img-top" alt="<%= article.title %>">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div>
            <div class="d-flex justify-content-between align-items-center mb-3">
              <span class="badge bg-success"><%= article.category %></span>
              <small class="text-muted"><%= article.date %></small>
            </div>
            <h3 class="h6 fw-bold mb-3"><%= article.title %></h3>
            <p class="text-muted small mb-4"><%= article.summary %></p>
          </div>
          <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-auto">
            <small class="text-muted fw-semibold">By <%= article.author %></small>
            <a href="/articles/<%= article.slug %>" class="btn btn-sm btn-success px-3">Read More <i class="fas fa-chevron-right ms-1" style="font-size: 0.75rem;"></i></a>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<!-- Newsletter Signup -->
<div class="py-5 bg-light rounded-3 shadow-sm border mb-5 fade-in">
  <div class="container px-4 text-center">
    <div class="row">
      <div class="col-lg-8 mx-auto">
        <h2 class="h4 fw-bold mb-3">Subscribe to EcoRecycle Newsletter</h2>
        <p class="text-muted small mb-4">Receive monthly tips, news updates, and points redemption alerts.</p>
        <form class="row g-2 justify-content-center">
          <div class="col-md-8">
            <div class="input-group">
              <input type="email" class="form-control border-end-0" placeholder="Your email address" aria-label="Your email address" style="border-radius: var(--radius-sm) 0 0 var(--radius-sm) !important;">
              <button class="btn btn-success" type="submit" style="border-radius: 0 var(--radius-sm) var(--radius-sm) 0 !important;">Subscribe</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('[data-category]');
    const articleCards = document.querySelectorAll('.article-card');
    
    filterButtons.forEach(button => {
      button.addEventListener('click', function() {
        // Remove active class and outline/background classes
        filterButtons.forEach(btn => {
          btn.classList.remove('active', 'btn-success');
          btn.classList.add('btn-outline-success');
        });
        
        // Add active class to clicked button
        this.classList.add('active', 'btn-success');
        this.classList.remove('btn-outline-success');
        
        const category = this.getAttribute('data-category');
        
        // Show/hide articles
        articleCards.forEach(card => {
          if (category === 'all' || card.getAttribute('data-category') === category) {
            card.style.display = 'block';
            card.classList.add('fade-in');
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>

<%- include('../partials/footer') %>