<%- include('../partials/header') %>

<div class="row g-4 mt-2 mb-5">
  
  <!-- Main Article Content -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm p-4">
      <div class="card-body">
        
        <div class="mb-4">
          <span class="badge bg-success mb-3"><%= article.category %></span>
          <h1 class="h2 fw-extrabold mb-3 text-dark"><%= article.title %></h1>
          
          <div class="d-flex align-items-center text-muted small pb-3 border-bottom">
            <div class="d-flex align-items-center me-4">
              <i class="fas fa-user-edit me-2 text-primary"></i>
              <span>By <%= article.author %></span>
            </div>
            <div class="d-flex align-items-center">
              <i class="fas fa-calendar-alt me-2 text-primary"></i>
              <span><%= article.date %></span>
            </div>
          </div>
        </div>
        
        <img src="<%= article.image %>" class="img-fluid rounded-3 mb-4 w-100" style="max-height: 400px; object-fit: cover;" alt="<%= article.title %>">
        
        <div class="article-rich-text text-muted" style="font-size: 1.05rem; line-height: 1.8;">
          <%- article.content %>
        </div>
        
        <div class="mt-5 pt-3 border-top d-flex justify-content-between align-items-center flex-wrap">
          <a href="/articles" class="btn btn-outline-success"><i class="fas fa-arrow-left me-2"></i> Back to Articles</a>
          <div class="d-flex gap-2 align-items-center mt-2 mt-sm-0">
            <span class="small text-muted fw-bold">Share:</span>
            <a href="#" class="btn btn-sm btn-outline-light text-dark border"><i class="fab fa-facebook-f"></i></a>
            <a href="#" class="btn btn-sm btn-outline-light text-dark border"><i class="fab fa-twitter"></i></a>
            <a href="#" class="btn btn-sm btn-outline-light text-dark border"><i class="fab fa-linkedin-in"></i></a>
          </div>
        </div>
        
      </div>
    </div>
  </div>
  
  <!-- Related Articles Sidebar -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm p-4 mb-4">
      <div class="card-body">
        <h3 class="h5 fw-bold mb-4 border-bottom pb-2">Related Articles</h3>
        
        <% if (article.relatedArticles && article.relatedArticles.length > 0) { %>
          <% article.relatedArticles.forEach(related => { %>
            <div class="mb-4">
              <img src="<%= related.image %>" class="img-fluid rounded-3 mb-2 w-100" style="height: 120px; object-fit: cover;" alt="<%= related.title %>">
              <h4 class="h6 fw-bold mb-1"><a href="/articles/<%= related.slug %>" class="text-dark text-decoration-none hover-primary"><%= related.title %></a></h4>
              <p class="text-muted small text-truncate" style="max-width: 250px;"><%= related.summary %></p>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-muted small">No related articles found.</p>
        <% } %>
        
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>