                  <i class="fas fa-trash-alt"></i>
                </div>
                <h3 class="h6 fw-bold mb-2">Reduce E-Waste</h3>
                <p class="text-muted small mb-0">Educate consumers on DIY repairs and maintenance to extend device longevity.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 card-hover">
              <div class="card-body text-center">
                <div class="display-6 text-success mb-3 bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 65px; height: 65px;">
                  <i class="fas fa-truck"></i>
                </div>
                <h3 class="h6 fw-bold mb-2">Increase Collection</h3>
                <p class="text-muted small mb-0">Expand doorstep pickup routes to cover rural and suburban regions.</p>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4 card-hover">
              <div class="card-body text-center">
                <div class="display-6 text-success mb-3 bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 65px; height: 65px;">
                  <i class="fas fa-university"></i>
                </div>
                <h3 class="h6 fw-bold mb-2">Compliance & Safety</h3>
                <p class="text-muted small mb-0">Partner exclusively with state-authorized pollution board processing facilities.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

