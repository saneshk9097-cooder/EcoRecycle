<%- include('../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">About EcoRecycle</h1>
    <p class="text-muted lead">We are dedicated to building sustainable infrastructure for electronic waste collection, raw resource retrieval, and public awareness.</p>
  </div>
</div>

<!-- Mission Section -->
<section class="mb-5 fade-in">
  <div class="row align-items-center g-4">
    <div class="col-lg-6">
      <img src="https://images.unsplash.com/photo-1532996122724-e3c354a0b15b?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80" alt="Our Mission" class="img-fluid rounded-3 shadow-premium">
    </div>
    <div class="col-lg-6">
      <h2 class="h3 fw-bold mb-3">Our Dedicated Mission</h2>
      <p class="text-muted">Our goal is to curb the toxicity of electronic waste in landfills. We provide individuals and enterprises with verified, pollution-board-approved drop-off routes, making responsible disposal easier than ever.</p>
      <p class="text-muted">We champion a **Circular Economy**—where components are reclaimed, heavy toxic metals are isolated, and raw materials are fed back into local electronics manufacturing.</p>
      <div class="d-flex flex-wrap gap-3 mt-4">
        <div class="d-flex align-items-center bg-light border rounded-pill px-3 py-2">
          <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px;">
            <i class="fas fa-leaf" style="font-size: 0.8rem;"></i>
          </div>
          <span class="small fw-semibold text-dark">Environmental Safety</span>
        </div>
        <div class="d-flex align-items-center bg-light border rounded-pill px-3 py-2">
          <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 28px; height: 28px;">
            <i class="fas fa-sync" style="font-size: 0.8rem;"></i>
          </div>
          <span class="small fw-semibold text-dark">Circular Economy</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Vision Section -->
<section class="mb-5 py-5 bg-light rounded-3 shadow-sm fade-in">
