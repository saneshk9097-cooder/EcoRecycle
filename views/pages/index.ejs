<%- include('../partials/header') %>

<!-- Hero Section -->
<section class="hero-wrapper fade-in">
  <div class="row align-items-center g-4">
    <div class="col-lg-6">
      <span class="badge bg-success mb-3 py-2 px-3 fw-bold">EcoRecycle E-Waste Portal</span>
      <h1 class="display-4 fw-extrabold mb-3 text-dark">Tackling the E-Waste Crisis Together</h1>
      <p class="lead mb-4 text-muted">Join our sustainable mission to recycle, reduce, and reuse old electronics. Manage your electronic waste efficiently, earn rewards, and track your ecological impact.</p>
      <div class="d-flex flex-wrap gap-2">
        <a href="/recycling/pickup" class="btn btn-success btn-lg px-4"><i class="fas fa-truck me-2"></i> Schedule a Pickup</a>
        <a href="/recycling/centers" class="btn btn-outline-success btn-lg px-4"><i class="fas fa-map-marker-alt me-2"></i> Find Recycling Centers</a>
      </div>
    </div>
    <div class="col-lg-6">
      <img src="https://images.unsplash.com/photo-1605600659873-d808a13e4d2a?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80" alt="E-Waste Recycling" class="img-fluid rounded-3 shadow-premium">
    </div>
  </div>
</section>

<!-- Key Stats Section -->
<section class="mb-5 py-4 fade-in">
  <div class="text-center mb-5">
    <h2 class="h3 fw-extrabold">The E-Waste Challenge</h2>
    <p class="text-muted small">Global statistics indicating the severity of electronic discard</p>
  </div>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm p-4 text-center card-hover">
        <div class="card-body">
          <div class="display-6 text-success mb-3 bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 70px; height: 70px;">
            <i class="fas fa-chart-line"></i>
          </div>
          <h3 class="h5 fw-bold mb-2">74 Million Metric Tons</h3>
          <p class="text-muted small mb-0">Projected global annual electronic waste volume generated by the year 2030.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm p-4 text-center card-hover">
        <div class="card-body">
          <div class="display-6 text-success mb-3 bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 70px; height: 70px;">
            <i class="fas fa-recycle"></i>
          </div>
          <h3 class="h5 fw-bold mb-2">17.4% Recycled</h3>
          <p class="text-muted small mb-0">Only a minor fraction of global e-waste is documented as properly collected and recycled.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm p-4 text-center card-hover">
        <div class="card-body">
          <div class="display-6 text-success mb-3 bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 70px; height: 70px;">
            <i class="fas fa-hand-holding-usd"></i>
          </div>
          <h3 class="h5 fw-bold mb-2">$57 Billion Lost</h3>
          <p class="text-muted small mb-0">High-value metals like gold and copper are discarded annually instead of being recovered.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Our Services Section -->
<section class="mb-5 py-4 fade-in">
  <div class="text-center mb-5">
    <h2 class="h3 fw-extrabold">Services We Provide</h2>
    <p class="text-muted small">Convenient options to discard e-waste safely</p>
  </div>
  <div class="row g-4">
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-0 shadow-sm card-hover">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div>
            <div class="text-success mb-3 fs-2"><i class="fas fa-map-marked-alt"></i></div>
            <h3 class="h5 fw-bold mb-2">Recycling Center Locator</h3>
            <p class="text-muted small mb-4">Find authorized state and central pollution board certified centers nearest to your area.</p>
          </div>
          <a href="/recycling/centers" class="btn btn-outline-success btn-sm w-100 mt-auto">Find Drop-Off Centers</a>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-0 shadow-sm card-hover">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div>
            <div class="text-success mb-3 fs-2"><i class="fas fa-truck-moving"></i></div>
            <h3 class="h5 fw-bold mb-2">Doorstep Pickups</h3>
            <p class="text-muted small mb-4">Schedule a collection route. Our logistics team will collect bulky electronics from your site.</p>
          </div>
          <a href="/recycling/pickup" class="btn btn-outline-success btn-sm w-100 mt-auto">Book Pickup Request</a>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 border-0 shadow-sm card-hover">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div>
            <div class="text-success mb-3 fs-2"><i class="fas fa-graduation-cap"></i></div>
            <h3 class="h5 fw-bold mb-2">Education & Awareness</h3>
            <p class="text-muted small mb-4">Read articles, view documentaries, and understand the science of e-waste recycling.</p>
          </div>
          <a href="/education" class="btn btn-outline-success btn-sm w-100 mt-auto">Start Learning</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Call to Action -->
<section class="py-5 text-white rounded-3 shadow fade-in" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);">
  <div class="container text-center py-3">
    <h2 class="text-white fw-bold mb-3">Ready to Make an Impact?</h2>
    <p class="lead text-white opacity-75 mb-4 max-width-600 mx-auto">Create a profile to log your recycled devices, earn reward points, and track carbon saved.</p>
    <a href="/register" class="btn btn-light btn-lg text-success px-5 fw-bold shadow-sm">Join EcoRecycle Today</a>
  </div>
</section>

<%- include('../partials/footer') %>