<%- include('../../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">E-Waste Reduction Tips</h1>
    <p class="text-muted lead">Practical and actionable tips you can follow at home or work to minimize electronic waste.</p>
  </div>
</div>

<!-- Tips Grid -->
<div class="row g-4 mb-5">
  <% tips.forEach((tip, index) => { %>
    <div class="col-md-6 col-lg-4 fade-in">
      <div class="card h-100 border-0 shadow-sm card-hover">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 48px; height: 48px; flex-shrink: 0; background-color: var(--primary-subtle) !important;">
              <%= index + 1 %>
            </div>
            <h3 class="h6 fw-bold mb-0 text-dark"><%= tip.title %></h3>
          </div>
          <p class="text-muted small mb-0"><%= tip.content %></p>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<!-- Extra tip banner -->
<div class="py-5 text-white rounded-3 shadow mb-5 fade-in" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);">
  <div class="container px-4 text-center py-2">
    <h2 class="text-white fw-bold mb-3">Extend Device Life First</h2>
    <p class="lead text-white opacity-75 mb-4 max-width-600 mx-auto">Before discarding, see if upgrading component parts (like SSD storage or RAM modules) can speed up your computer.</p>
    <a href="/articles" class="btn btn-light btn-lg text-success px-5 fw-bold shadow-sm">Read Device Care Articles</a>
  </div>
</div>

<%- include('../../partials/footer') %>