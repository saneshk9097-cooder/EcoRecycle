<%- include('../../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">E-Waste Facts</h1>
    <p class="text-muted lead">Vital statistics, environmental threats, and research metrics compiled from global institutions.</p>
  </div>
</div>

<!-- Facts Grid -->
<div class="row g-4 mb-5">
  <% facts.forEach((fact, index) => { %>
    <div class="col-md-6 col-lg-4 fade-in">
      <div class="card h-100 border-0 shadow-sm card-hover">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div>
            <div class="d-flex align-items-center mb-3">
              <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; flex-shrink: 0;">
                <i class="fas fa-info-circle"></i>
              </div>
              <h3 class="h6 fw-bold mb-0 text-dark"><%= fact.title %></h3>
            </div>
            <p class="text-muted small mb-4"><%= fact.content %></p>
          </div>
          
          <div class="border-top pt-3 mt-auto">
            <span class="small text-muted fw-semibold" style="font-size: 0.75rem;"><i class="fas fa-quote-left me-1 text-primary"></i> Source: <%= fact.source %></span>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<!-- Extra Fact banner -->
<div class="py-5 text-white rounded-3 shadow mb-5 fade-in" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);">
  <div class="container px-4 text-center py-2">
    <h2 class="text-white fw-bold mb-3">Small Changes, Large Impact</h2>
    <p class="lead text-white opacity-75 mb-4 max-width-600 mx-auto">Recycling 1 million mobile phones retrieves approximately 16,000 kg of copper, 350 kg of silver, and 34 kg of gold.</p>
    <a href="/recycling/pickup" class="btn btn-light btn-lg text-success px-5 fw-bold shadow-sm">Schedule a Pickup Route</a>
  </div>
</div>

<%- include('../../partials/footer') %>