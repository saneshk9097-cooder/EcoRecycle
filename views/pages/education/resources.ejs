<%- include('../../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">E-Waste Resources</h1>
    <p class="text-muted lead">Directories, global coalitions, academic research reports, and international organizations.</p>
  </div>
</div>

<!-- Resources List -->
<div class="row g-4 mb-5">
  <% resources.forEach(resource => { %>
    <div class="col-md-6 fade-in">
      <div class="card h-100 border-0 shadow-sm p-4 card-hover">
        <div class="card-body d-flex flex-column justify-content-between">
          <div>
            <div class="d-flex align-items-center mb-3">
              <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 46px; height: 46px; flex-shrink: 0; background-color: var(--primary-subtle) !important;">
                <i class="fas fa-external-link-alt text-primary" style="font-size: 0.9rem;"></i>
              </div>
              <h3 class="h6 fw-bold mb-0 text-dark"><%= resource.title %></h3>
            </div>
            <p class="text-muted small mb-4"><%= resource.description %></p>
          </div>
          
          <div class="border-top pt-3 mt-auto">
            <a href="<%= resource.url %>" target="_blank" class="btn btn-sm btn-success px-4">Visit Organization <i class="fas fa-external-link-alt ms-1" style="font-size: 0.75rem;"></i></a>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('../../partials/footer') %>