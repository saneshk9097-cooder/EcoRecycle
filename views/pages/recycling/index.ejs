<%- include('../../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">E-Waste Recycling</h1>
    <p class="text-muted lead">Electronic waste is composed of complex and toxic substances. Proper recycling ensures raw materials are recovered and toxic chemicals are safely isolated.</p>
  </div>
</div>

<!-- Recycling Process Steps -->
<section class="mb-5 py-4 fade-in">
  <h2 class="h4 fw-bold mb-4 text-center">The Processing Cycle</h2>
  <div class="row g-4">
    <div class="col-md-3">
      <div class="card h-100 border-0 shadow-sm p-4 text-center card-hover">
        <div class="card-body">
          <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
            <i class="fas fa-box-open fa-2x"></i>
          </div>
          <h3 class="h6 fw-bold mb-2">1. Collection</h3>
          <p class="text-muted small mb-0">E-waste is safely gathered via doorstep pickups or drop-off centers.</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100 border-0 shadow-sm p-4 text-center card-hover">
        <div class="card-body">
          <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
            <i class="fas fa-sort fa-2x"></i>
          </div>
          <h3 class="h6 fw-bold mb-2">2. Sorting</h3>
          <p class="text-muted small mb-0">Devices are categorized by item type, components, and condition.</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100 border-0 shadow-sm p-4 text-center card-hover">
        <div class="card-body">
          <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
            <i class="fas fa-tools fa-2x"></i>
          </div>
          <h3 class="h6 fw-bold mb-2">3. Dismantling</h3>
          <p class="text-muted small mb-0">Devices are disassembled into circuit boards, plastics, and glass components.</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card h-100 border-0 shadow-sm p-4 text-center card-hover">
        <div class="card-body">
          <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 70px; height: 70px;">
            <i class="fas fa-recycle fa-2x"></i>
          </div>
          <h3 class="h6 fw-bold mb-2">4. Recovery</h3>
          <p class="text-muted small mb-0">Precious metals are isolated and sent back for clean component manufacturing.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Item Categories Section -->
<section class="mb-5 py-5 bg-light rounded-3 shadow-sm fade-in">
  <div class="container px-4">
    <h2 class="h4 fw-bold mb-4 text-center">What Categories Can Be Recycled?</h2>
    <div class="row g-4 mt-2">
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-3 card-hover">
          <div class="card-body">
            <h3 class="h6 fw-bold mb-3"><i class="fas fa-laptop text-success me-2"></i>Computing</h3>
            <ul class="list-unstyled small text-muted mb-0">
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Laptops & Desktops</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Monitors & Projectors</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Keyboards, Mice & Accessories</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Printers & Scanners</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-3 card-hover">
          <div class="card-body">
            <h3 class="h6 fw-bold mb-3"><i class="fas fa-mobile-alt text-success me-2"></i>Consumer Electronics</h3>
            <ul class="list-unstyled small text-muted mb-0">
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Mobile Phones & Tablets</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Smart TVs & Home Theater</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Cameras & Voice Recorders</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Gaming Consoles</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card h-100 border-0 shadow-sm p-3 card-hover">
          <div class="card-body">
            <h3 class="h6 fw-bold mb-3"><i class="fas fa-battery-half text-success me-2"></i>Bulb & Battery</h3>
            <ul class="list-unstyled small text-muted mb-0">
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Rechargeable Batteries</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Led, Halogen & Fluorescent Bulbs</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Copper wires & chargers</li>
              <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Small home appliances</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Call to action -->
<section class="py-5 text-white rounded-3 shadow fade-in" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-hover) 100%);">
  <div class="container text-center py-2">
    <h2 class="text-white fw-bold mb-3">Ready to Recycle?</h2>
    <p class="lead text-white opacity-75 mb-4 max-width-600 mx-auto">Book a doorstep pickup request. Our certified collection vehicles will pick up your old devices directly.</p>
    <a href="/recycling/pickup" class="btn btn-light btn-lg text-success px-5 fw-bold shadow-sm">Schedule Pickup Now</a>
  </div>
</section>

<%- include('../../partials/footer') %>