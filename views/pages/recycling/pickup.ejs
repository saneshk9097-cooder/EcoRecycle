<%- include('../../partials/header') %>

<div class="row mb-5">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">Schedule a Pickup</h1>
    <p class="text-muted lead">Can't make it to a recycling center? Let our team collect your e-waste directly from your home or office.</p>
  </div>
</div>

<div class="row g-4">
  <!-- Left Side: Form -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm p-4">
      <div class="card-body">
        
        <form action="/recycling/pickup" method="POST" class="needs-validation" novalidate>
          
          <!-- Contact Info -->
          <div class="mb-4">
            <h3 class="h5 mb-3 fw-bold border-bottom pb-2"><i class="fas fa-address-card text-success me-2"></i>Contact Details</h3>
            <div class="row g-3">
              <div class="col-md-6">
                <label for="firstName" class="form-label">First Name</label>
                <div class="input-group-premium">
                  <i class="fas fa-user"></i>
                  <input type="text" class="form-control" id="firstName" name="firstName" placeholder="John" required>
                  <div class="invalid-feedback">Please provide your first name.</div>
                </div>
              </div>
              <div class="col-md-6">
                <label for="lastName" class="form-label">Last Name</label>
                <div class="input-group-premium">
                  <i class="fas fa-user"></i>
                  <input type="text" class="form-control" id="lastName" name="lastName" placeholder="Doe" required>
                  <div class="invalid-feedback">Please provide your last name.</div>
                </div>
              </div>
              <div class="col-md-6">
                <label for="email" class="form-label">Email</label>
                <div class="input-group-premium">
                  <i class="fas fa-envelope"></i>
                  <input type="email" class="form-control" id="email" name="email" placeholder="john@example.com" required>
                  <div class="invalid-feedback">Please provide a valid email.</div>
                </div>
              </div>
              <div class="col-md-6">
                <label for="phone" class="form-label">Phone Number</label>
                <div class="input-group-premium">
                  <i class="fas fa-phone"></i>
                  <input type="tel" class="form-control" id="phone" name="phone" placeholder="+91 98765 43210" required>
                  <div class="invalid-feedback">Please provide your phone number.</div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Address Info -->
          <div class="mb-4">
            <h3 class="h5 mb-3 fw-bold border-bottom pb-2"><i class="fas fa-map-marker-alt text-success me-2"></i>Pickup Address</h3>
            <div class="row g-3">
              <div class="col-12">
                <label for="address" class="form-label">Street Address</label>
                <div class="input-group-premium">
                  <i class="fas fa-map-marker-alt"></i>
                  <input type="text" class="form-control" id="address" name="address" placeholder="Flat, Building name, Street address" required>
                  <div class="invalid-feedback">Please provide your street address.</div>
                </div>
              </div>
              
              <div class="col-md-6">
                <label for="city" class="form-label">City</label>
                <div class="input-group-premium">
                  <i class="fas fa-city"></i>
                  <input type="text" class="form-control" id="city" name="city" placeholder="Patna" required>
                  <div class="invalid-feedback">Please provide your city.</div>
                </div>
              </div>
              
              <div class="col-md-4">
                <label for="state" class="form-label">State</label>
                <select class="form-select" id="state" name="state" required>
                  <option value="" selected disabled>Select State</option>
                  <option value="AN">Andaman and Nicobar Islands</option>
                  <option value="AP">Andhra Pradesh</option>
                  <option value="AR">Arunachal Pradesh</option>
                  <option value="AS">Assam</option>
                  <option value="BR">Bihar</option>
                  <option value="CH">Chandigarh</option>
                  <option value="CT">Chhattisgarh</option>
                  <option value="DN">Dadra and Nagar Haveli and Daman and Diu</option>
                  <option value="DL">Delhi</option>
                  <option value="GA">Goa</option>
                  <option value="GJ">Gujarat</option>
                  <option value="HR">Haryana</option>
                  <option value="HP">Himachal Pradesh</option>
                  <option value="JK">Jammu and Kashmir</option>
                  <option value="JH">Jharkhand</option>
                  <option value="KA">Karnataka</option>
                  <option value="KL">Kerala</option>
                  <option value="LA">Ladakh</option>
                  <option value="LD">Lakshadweep</option>
                  <option value="MP">Madhya Pradesh</option>
                  <option value="MH">Maharashtra</option>
                  <option value="MN">Manipur</option>
                  <option value="ML">Meghalaya</option>
                  <option value="MZ">Mizoram</option>
                  <option value="NL">Nagaland</option>
                  <option value="OR">Odisha</option>
                  <option value="PY">Puducherry</option>
                  <option value="PB">Punjab</option>
                  <option value="RJ">Rajasthan</option>
                  <option value="SK">Sikkim</option>
                  <option value="TN">Tamil Nadu</option>
                  <option value="TG">Telangana</option>
                  <option value="TR">Tripura</option>
                  <option value="UP">Uttar Pradesh</option>
                  <option value="UK">Uttarakhand</option>
                  <option value="WB">West Bengal</option>
                </select>
                <div class="invalid-feedback">Please select your state.</div>
              </div>
              
              <div class="col-md-2">
                <label for="zip" class="form-label">Pincode</label>
                <input type="text" class="form-control" id="zip" name="zip" placeholder="800001" required>
                <div class="invalid-feedback">Please provide your pincode.</div>
              </div>
              
              <div class="col-12">
                <label for="addressNotes" class="form-label">Address Notes (Optional)</label>
                <textarea class="form-control" id="addressNotes" name="addressNotes" rows="2" placeholder="Apartment number, building name, special directions, etc."></textarea>
              </div>
            </div>
          </div>
          
          <!-- Items to Recycle -->
          <div class="mb-4">
            <h3 class="h5 mb-3 fw-bold border-bottom pb-2"><i class="fas fa-boxes text-success me-2"></i>Items to Recycle</h3>
            <p class="small text-muted mb-3">Select the categories of electronic devices you want picked up:</p>
            
            <div class="row g-2 mb-3">
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="computers" name="items" value="Computers & Laptops">
                    <label class="form-check-label fw-bold small" for="computers">Computers & Laptops</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="monitors" name="items" value="Monitors & Displays">
                    <label class="form-check-label fw-bold small" for="monitors">Monitors & Displays</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="phones" name="items" value="Phones & Tablets">
                    <label class="form-check-label fw-bold small" for="phones">Phones & Tablets</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="printers" name="items" value="Printers & Scanners">
                    <label class="form-check-label fw-bold small" for="printers">Printers & Scanners</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="tvs" name="items" value="Televisions">
                    <label class="form-check-label fw-bold small" for="tvs">Televisions</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="batteries" name="items" value="Batteries">
                    <label class="form-check-label fw-bold small" for="batteries">Batteries</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="appliances" name="items" value="Small Appliances">
                    <label class="form-check-label fw-bold small" for="appliances">Small Appliances</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="cables" name="items" value="Cables & Chargers">
                    <label class="form-check-label fw-bold small" for="cables">Cables & Chargers</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6 col-xl-4">
                <div class="form-check card p-2 bg-light bg-opacity-50">
                  <div>
                    <input class="form-check-input ms-1 me-2" type="checkbox" id="other" name="items" value="Other Electronics">
                    <label class="form-check-label fw-bold small" for="other">Other Electronics</label>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="mb-3">
              <label for="itemDetails" class="form-label">Item Details (Quantities, models, etc.)</label>
              <textarea class="form-control" id="itemDetails" name="itemDetails" rows="3" placeholder="Please list the estimated quantities and details of the devices you wish to recycle..." required></textarea>
              <div class="invalid-feedback">Please describe the items you wish to recycle.</div>
            </div>
          </div>
          
          <!-- Date and Time selection -->
          <div class="mb-4">
            <h3 class="h5 mb-3 fw-bold border-bottom pb-2"><i class="fas fa-calendar-alt text-success me-2"></i>Scheduling Details</h3>
            <div class="row g-3">
              <div class="col-md-6">
                <label for="pickupDate" class="form-label">Preferred Date</label>
                <div class="input-group-premium">
                  <i class="fas fa-calendar"></i>
                  <input type="date" class="form-control" id="pickupDate" name="pickupDate" required>
                  <div class="invalid-feedback">Please select a preferred date.</div>
                </div>
              </div>
              <div class="col-md-6">
                <label for="pickupTime" class="form-label">Preferred Time Slot</label>
                <select class="form-select" id="pickupTime" name="pickupTime" required>
                  <option value="" selected disabled>Select Time Slot</option>
                  <option value="Morning (8:00 AM - 12:00 PM)">Morning (8:00 AM - 12:00 PM)</option>
                  <option value="Afternoon (12:00 PM - 4:00 PM)">Afternoon (12:00 PM - 4:00 PM)</option>
                  <option value="Evening (4:00 PM - 7:00 PM)">Evening (4:00 PM - 7:00 PM)</option>
                </select>
                <div class="invalid-feedback">Please select a preferred time slot.</div>
              </div>
              <div class="col-12">
                <label for="pickupNotes" class="form-label">Additional Logistics Notes (Optional)</label>
                <textarea class="form-control" id="pickupNotes" name="pickupNotes" rows="2" placeholder="Any building gate instructions or delivery protocols?"></textarea>
              </div>
            </div>
          </div>
          
          <!-- Consent checkbox -->
          <div class="mb-4">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="terms" name="terms" required>
              <label class="form-check-label text-muted small" for="terms">
                I agree to the <a href="#" class="text-success text-decoration-none fw-bold" data-bs-toggle="modal" data-bs-target="#termsModal">Terms and Conditions</a> for e-waste pickup services.
              </label>
              <div class="invalid-feedback">You must agree to the terms and conditions.</div>
            </div>
          </div>
          
          <div class="d-grid">
            <button type="submit" class="btn btn-success py-2">Submit Pickup Request</button>
          </div>
          
        </form>
      </div>
    </div>
  </div>
  
  <!-- Right Side: Sidebar Info -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <h3 class="h5 mb-3 fw-bold border-bottom pb-2">How It Works</h3>
        <ul class="list-unstyled mb-0" style="font-size: 0.9rem;">
          <li class="mb-3 d-flex">
            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 28px; height: 28px; flex-shrink: 0;">
              1
            </div>
            <div>
              <span class="fw-bold d-block">Submit Form</span>
              Provide your details, pickup location, and e-waste item list.
            </div>
          </li>
          <li class="mb-3 d-flex">
            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 28px; height: 28px; flex-shrink: 0;">
              2
            </div>
            <div>
              <span class="fw-bold d-block">Slot Confirmation</span>
              Our scheduling desk will contact you to finalize the appointment.
            </div>
          </li>
          <li class="mb-3 d-flex">
            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 28px; height: 28px; flex-shrink: 0;">
              3
            </div>
            <div>
              <span class="fw-bold d-block">Collection Day</span>
              A driver arrives with proper handling materials to load the items.
            </div>
          </li>
        </ul>
      </div>
    </div>
    
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <h3 class="h5 mb-3 fw-bold border-bottom pb-2">Recycle Guidelines</h3>
        <ul class="list-unstyled mb-0 small text-muted">
          <li class="mb-2 d-flex align-items-center">
            <i class="fas fa-check text-success me-2"></i> Backup & remove personal accounts from hard drives.
          </li>
          <li class="mb-2 d-flex align-items-center">
            <i class="fas fa-check text-success me-2"></i> Remove lithium batteries from laptops if safe.
          </li>
          <li class="mb-2 d-flex align-items-center">
            <i class="fas fa-check text-success me-2"></i> Bundle cables together with ties.
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- Terms Modal -->
<div class="modal fade" id="termsModal" tabindex="-1" aria-labelledby="termsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: var(--radius-md);">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="termsModalLabel">Terms and Conditions</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4 text-muted small">
        <h6 class="fw-bold text-dark">1. Service Availability</h6>
        <p>E-waste pickups are processed during standard working hours. Someone above 18 years must be present during collection.</p>
        <h6 class="fw-bold text-dark">2. Device Verification</h6>
        <p>Only electronic components can be recycled. Hazardous chemical containers, toxic materials, and non-e-waste garbage are prohibited.</p>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-success px-4" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>