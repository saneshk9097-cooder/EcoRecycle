<%- include('../partials/header') %>

<div class="row min-vh-75 align-items-center justify-content-center mt-3">
  <div class="col-lg-6 col-md-8 col-12">
    <div class="card border-0 shadow-lg p-4 p-md-5 fade-in">
      
      <div class="mb-4 text-center">
        <div class="bg-success-subtle rounded-circle p-3 d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px; background-color: var(--primary-subtle) !important;">
          <i class="fas fa-edit text-success fs-3"></i>
        </div>
        <h1 class="fw-extrabold h3">Edit Your Review</h1>
        <p class="text-muted">Modify your rating and comment feedback for the EcoRecycle community.</p>
      </div>

      <form action="/reviews/<%= review._id %>/edit" method="POST" class="needs-validation" novalidate>
        
        <!-- Rating Score Selection -->
        <div class="mb-3">
          <label for="rating" class="form-label">Overall Rating</label>
          <select class="form-select" id="rating" name="rating" required>
            <option value="" disabled>Select star rating...</option>
            <option value="5" <%= review.rating === 5 ? 'selected' : '' %>>⭐⭐⭐⭐⭐ 5 Stars (Excellent)</option>
            <option value="4" <%= review.rating === 4 ? 'selected' : '' %>>⭐⭐⭐⭐ 4 Stars (Very Good)</option>
            <option value="3" <%= review.rating === 3 ? 'selected' : '' %>>⭐⭐⭐ 3 Stars (Good)</option>
            <option value="2" <%= review.rating === 2 ? 'selected' : '' %>>⭐⭐ 2 Stars (Fair)</option>
            <option value="1" <%= review.rating === 1 ? 'selected' : '' %>>⭐ 1 Star (Poor)</option>
          </select>
          <div class="invalid-feedback">
            Please choose a rating score.
          </div>
        </div>

        <!-- Comment Textarea -->
        <div class="mb-4">
          <label for="comment" class="form-label">Review Comment</label>
          <textarea class="form-control" id="comment" name="comment" rows="5" placeholder="Tell us what you think..." required minlength="5"><%= review.comment %></textarea>
          <div class="invalid-feedback">
            Please write a brief comment (minimum 5 characters).
          </div>
        </div>

        <!-- Submit & Cancel buttons -->
        <div class="row g-2">
          <div class="col-6">
            <a href="/reviews" class="btn btn-outline-secondary w-100 py-2">Cancel</a>
          </div>
          <div class="col-6">
            <button type="submit" class="btn btn-success w-100 py-2">Save Changes</button>
          </div>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
