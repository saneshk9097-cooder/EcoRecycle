<%- include('../partials/header') %>

<div class="row min-vh-75 align-items-center justify-content-center mt-3">
  <div class="col-md-8 col-lg-6 col-12">
    <div class="card border-0 shadow-lg p-4 p-md-5 text-center fade-in">
      
      <!-- Profile Header / Avatar -->
      <div class="mb-4 position-relative">
        <div class="mx-auto mb-3 shadow-sm d-flex align-items-center justify-content-center text-white fw-bold" style="width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); font-size: 2.25rem;">
          <% if (typeof user !== 'undefined' && user) { %>
            <% if (user.profilePicture) { %>
              <img src="<%= user.profilePicture %>" alt="Profile Picture" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
            <% } else { %>
              <%= (user.firstName.charAt(0) + user.lastName.charAt(0)).toUpperCase() %>
            <% } %>
          <% } else { %>
            UR
          <% } %>
        </div>
        <h1 class="fw-extrabold h3 mb-1">
          <% if (typeof user !== 'undefined' && user) { %>
            <%= user.firstName %> <%= user.lastName %>
          <% } else { %>
            User Profile
          <% } %>
        </h1>
        <p class="text-muted small">@<%= typeof user !== 'undefined' && user ? user.username : 'username' %></p>
      </div>

      <!-- Profile Details -->
      <div class="card bg-light border-0 p-4 mb-4 text-start rounded-3">
        <div class="row g-3">
          <div class="col-12 border-bottom pb-2">
            <span class="text-muted small d-block uppercase tracking-wider mb-1" style="font-size: 0.75rem; font-weight: 700;">Email Address</span>
            <span class="fw-semibold text-dark-subtle" style="color: var(--text-color) !important;">
              <%= typeof user !== 'undefined' && user ? user.email : 'name@domain.com' %>
            </span>
          </div>

          <div class="col-12 border-bottom pb-2">
            <span class="text-muted small d-block uppercase tracking-wider mb-1" style="font-size: 0.75rem; font-weight: 700;">Account Linkage</span>
            <span class="badge bg-success py-2 px-3 mt-1" style="font-size: 0.8rem;">
              <% if (typeof user !== 'undefined' && user && user.googleId) { %>
                <i class="fab fa-google me-1"></i> Google Connected
              <% } else { %>
                <i class="fas fa-lock me-1"></i> Password Authentication
              <% } %>
            </span>
          </div>

          <% if (typeof user !== 'undefined' && user && (user.phone || user.address)) { %>
            <div class="col-12">
              <span class="text-muted small d-block uppercase tracking-wider mb-1" style="font-size: 0.75rem; font-weight: 700;">Contact Details</span>
              <p class="mb-1 text-dark-subtle small" style="color: var(--text-color) !important;">
                <i class="fas fa-phone me-2 text-success"></i> <%= user.phone || 'N/A' %>
              </p>
              <p class="mb-0 text-dark-subtle small" style="color: var(--text-color) !important;">
                <i class="fas fa-map-marker-alt me-2 text-success"></i> <%= user.address %>, <%= user.city %>, <%= user.state %> <%= user.zip %>
              </p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="d-flex gap-2">
        <a href="/dashboard" class="btn btn-outline-success w-50 py-2">
          <i class="fas fa-chart-line me-2"></i> Dashboard
        </a>
        <a href="#" class="btn btn-danger w-50 py-2 btn-logout-trigger">
          <i class="fas fa-sign-out-alt me-2"></i> Logout
        </a>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/footer') %>
