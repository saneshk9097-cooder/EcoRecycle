<%- include('../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">Community Reviews</h1>
    <p class="text-muted lead">Read what our members say about our recycling centers, pickups, and educational services.</p>
  </div>
</div>

<!-- Reviews Dashboard Stats -->
<div class="row g-4 mb-5 fade-in">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 p-4 text-center d-flex flex-column justify-content-center align-items-center">
      <h2 class="display-3 fw-extrabold text-success mb-2"><%= averageRating %></h2>
      <div class="rating-stars text-warning fs-4 mb-2">
        <% const roundedRating = Math.round(parseFloat(averageRating) || 0); %>
        <% for (let i = 1; i <= 5; i++) { %>
          <i class="<%= i <= roundedRating ? 'fas' : 'far' %> fa-star"></i>
        <% } %>
      </div>
      <p class="text-muted small mb-0">Average Rating based on <%= totalReviews %> reviews</p>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card border-0 shadow-sm h-100 p-4">
      <h4 class="fw-bold mb-3">Rating Breakdown</h4>
      <% 
        // Calculate breakdown percentages
        const starCounts = {5: 0, 4: 0, 3: 0, 2: 0, 1: 0};
        if (typeof reviews !== 'undefined' && reviews) {
          reviews.forEach(r => {
            if (starCounts[r.rating] !== undefined) {
              starCounts[r.rating]++;
            }
          });
        }
      %>
      <% for (let star = 5; star >= 1; star--) { %>
        <% 
          const count = starCounts[star];
          const pct = totalReviews > 0 ? ((count / totalReviews) * 100).toFixed(0) : 0;
        %>
        <div class="d-flex align-items-center mb-2">
          <span class="text-muted small me-2" style="width: 60px;"><%= star %> Stars</span>
          <div class="progress flex-grow-1 bg-light rounded-pill" style="height: 10px;">
            <div class="progress-bar bg-success rounded-pill" role="progressbar" style="width: <%= pct %>%" aria-valuenow="<%= pct %>" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <span class="text-muted small ms-3" style="width: 45px; text-align: right;"><%= count %></span>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Left Column: Submit a Review / Authentication Prompt -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm p-4 sticky-lg-top" style="top: 105px; z-index: 10;">
      <% if (typeof user !== 'undefined' && user) { %>
        <h4 class="fw-bold mb-3">Share Your Feedback</h4>
        <p class="text-muted small mb-4">Help us improve by rating your recycling, booking, or educational experience.</p>
        
        <form action="/reviews" method="POST" class="needs-validation" novalidate>
          <div class="mb-3">
            <label for="rating" class="form-label">Overall Rating</label>
            <select class="form-select" id="rating" name="rating" required>
              <option value="" disabled selected>Select star rating...</option>
              <option value="5">⭐⭐⭐⭐⭐ 5 Stars (Excellent)</option>
              <option value="4">⭐⭐⭐⭐ 4 Stars (Very Good)</option>
              <option value="3">⭐⭐⭐ 3 Stars (Good)</option>
              <option value="2">⭐⭐ 2 Stars (Fair)</option>
              <option value="1">⭐ 1 Star (Poor)</option>
            </select>
            <div class="invalid-feedback">
              Please choose a rating score.
            </div>
          </div>

          <div class="mb-4">
            <label for="comment" class="form-label">Review Comment</label>
            <textarea class="form-control" id="comment" name="comment" rows="4" placeholder="Tell us what you think..." required minlength="5"></textarea>
            <div class="invalid-feedback">
              Please write a brief comment (minimum 5 characters).
            </div>
          </div>

          <div class="d-grid">
            <button type="submit" class="btn btn-success">Submit Review</button>
          </div>
        </form>
      <% } else { %>
        <div class="text-center py-4">
          <div class="mb-3 text-success">
            <i class="fas fa-pen-fancy" style="font-size: 2.5rem;"></i>
          </div>
          <h4 class="fw-bold mb-2">Write a Review</h4>
          <p class="text-muted small mb-4">You must be signed in to submit reviews and rate your experience.</p>
          <div class="d-grid gap-2">
            <a href="/login" class="btn btn-success">Sign In</a>
            <a href="/register" class="btn btn-outline-success">Register Now</a>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Right Column: Reviews Timeline -->
  <div class="col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="fw-bold mb-0">What Our Members Say</h3>
      <span class="badge bg-success"><%= totalReviews %> Reviews</span>
    </div>

    <% if (typeof reviews !== 'undefined' && reviews && reviews.length > 0) { %>
      <div class="d-flex flex-column gap-4">
        <% reviews.forEach(review => { %>
          <div class="card border-0 shadow-sm p-4 fade-in">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <div class="d-flex align-items-center">
                <div class="user-avatar-initials d-flex align-items-center justify-content-center text-white fw-bold me-3" style="width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); font-size: 0.95rem; overflow: hidden;">
                  <% if (review.user && review.user.profilePicture) { %>
                    <img src="<%= review.user.profilePicture %>" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">
                  <% } else if (review.user && review.user.firstName && review.user.lastName) { %>
                    <%= (review.user.firstName.charAt(0) + review.user.lastName.charAt(0)).toUpperCase() %>
                  <% } else { %>
                    UR
                  <% } %>
                </div>
                <div>
                  <h6 class="fw-bold mb-0 text-dark-subtle" style="color: var(--text-color) !important;">
                    <% if (review.user && review.user.firstName && review.user.lastName) { %>
                      <%= review.user.firstName %> <%= review.user.lastName %>
                    <% } else { %>
                      User Reviewer
                    <% } %>
                  </h6>
                  <span class="text-muted small">
                    <i class="far fa-calendar-alt me-1"></i>
                    <%= new Date(review.createdAt).toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' }) %>
                  </span>
                </div>
              </div>

              <!-- Rating Badge -->
              <div class="rating-stars text-warning fs-5">
                <% for (let i = 1; i <= 5; i++) { %>
                  <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"></i>
                <% } %>
              </div>
            </div>

            <p class="text-muted mb-0" style="white-space: pre-line;"><%= review.comment %></p>

            <!-- Ownership Controls -->
            <% if (typeof user !== 'undefined' && user && review.user && review.user._id && review.user._id.toString() === user._id.toString()) { %>
              <div class="d-flex gap-3 justify-content-end mt-3 border-top pt-3">
                <a href="/reviews/<%= review._id %>/edit" class="btn btn-sm btn-outline-success d-flex align-items-center px-3">
                  <i class="fas fa-edit me-1"></i> Edit
                </a>
                <form action="/reviews/<%= review._id %>/delete" method="POST" class="m-0" onsubmit="return confirm('Are you sure you want to delete this review?');">
                  <button type="submit" class="btn btn-sm btn-outline-danger d-flex align-items-center px-3">
                    <i class="fas fa-trash-alt me-1"></i> Delete
                  </button>
                </form>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="card border-0 shadow-sm p-5 text-center fade-in">
        <div class="mb-4 text-muted">
          <i class="fas fa-comments" style="font-size: 4rem;"></i>
        </div>
        <h4 class="fw-bold">No Reviews Yet</h4>
        <p class="text-muted">Be the first to share your experience with the EcoRecycle community!</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
