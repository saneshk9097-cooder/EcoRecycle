<%- include('../partials/header') %>

<div class="row mb-5 mt-2">
  <div class="col-lg-8 mx-auto text-center">
    <h1 class="display-5 fw-extrabold mb-3">Contact Us</h1>
    <p class="text-muted lead">Have questions about e-waste disposal, or looking to partner with us for corporate pickups? Reach out!</p>
  </div>
</div>

<div class="row g-5 mb-5">
  <!-- Contact Info Sidebar -->
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm p-4 h-100">
      <div class="card-body">
        <h2 class="h4 fw-bold mb-4">Get in Touch</h2>
        
        <div class="d-flex mb-4">
          <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;">
            <i class="fas fa-map-marker-alt"></i>
          </div>
          <div>
            <h3 class="h6 mb-1 fw-bold">Office Address</h3>
            <p class="small text-muted mb-0">Plot No. 22, Kankarbagh Main Road,<br>Patna, Bihar, India - 800020</p>
          </div>
        </div>
        
        <div class="d-flex mb-4">
          <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;">
            <i class="fas fa-phone"></i>
          </div>
          <div>
            <h3 class="h6 mb-1 fw-bold">Helpline</h3>
            <p class="small text-muted mb-0">(+91) 7644978283</p>
          </div>
        </div>
        
        <div class="d-flex mb-4">
          <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;">
            <i class="fas fa-envelope"></i>
          </div>
          <div>
            <h3 class="h6 mb-1 fw-bold">Support Email</h3>
            <p class="small text-muted mb-0"><a href="mailto:sanesh7644@gmail.com" class="text-success text-decoration-none">sanesh7644@gmail.com</a></p>
          </div>
        </div>
        
        <div class="d-flex mb-4">
          <div class="bg-success bg-opacity-10 text-success rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px; flex-shrink: 0;">
            <i class="fas fa-clock"></i>
          </div>
          <div>
            <h3 class="h6 mb-1 fw-bold">Working Hours</h3>
            <p class="small text-muted mb-0">Monday - Friday: 9:00 AM - 5:00 PM<br>Saturday: 10:00 AM - 2:00 PM<br>Sunday: Closed</p>
          </div>
        </div>
        
        <div class="mt-5 border-top pt-4">
          <h4 class="h6 fw-bold mb-3">Follow our updates:</h4>
          <div class="d-flex gap-3 fs-5">
            <a href="#" class="text-muted"><i class="fab fa-facebook"></i></a>
            <a href="#" class="text-muted"><i class="fab fa-twitter"></i></a>
            <a href="#" class="text-muted"><i class="fab fa-instagram"></i></a>
            <a href="#" class="text-muted"><i class="fab fa-linkedin"></i></a>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Contact Form -->
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm p-4 h-100">
      <div class="card-body">
        <h2 class="h4 fw-bold mb-4">Send Us a Message</h2>
        
        <form action="/contact" method="POST" class="needs-validation" novalidate>
          <div class="row g-3">
            <div class="col-md-6">
              <label for="firstName" class="form-label">First Name</label>
              <div class="input-group-premium">
                <i class="fas fa-user"></i>
                <input type="text" class="form-control" id="firstName" name="firstName" placeholder="John" value="<%= typeof formData !== 'undefined' ? formData.firstName : '' %>" required>
                <div class="invalid-feedback">First name is required.</div>
              </div>
            </div>
            <div class="col-md-6">
              <label for="lastName" class="form-label">Last Name</label>
              <div class="input-group-premium">
                <i class="fas fa-user"></i>
                <input type="text" class="form-control" id="lastName" name="lastName" placeholder="Doe" value="<%= typeof formData !== 'undefined' ? formData.lastName : '' %>" required>
                <div class="invalid-feedback">Last name is required.</div>
              </div>
            </div>
            <div class="col-md-6">
              <label for="email" class="form-label">Email</label>
              <div class="input-group-premium">
                <i class="fas fa-envelope"></i>
                <input type="email" class="form-control" id="email" name="email" placeholder="john@example.com" value="<%= typeof formData !== 'undefined' ? formData.email : '' %>" required>
                <div class="invalid-feedback">Valid email is required.</div>
              </div>
            </div>
            <div class="col-md-6">
              <label for="phone" class="form-label">Phone (Optional)</label>
              <div class="input-group-premium">
                <i class="fas fa-phone"></i>
                <input type="tel" class="form-control" id="phone" name="phone" placeholder="+91 98765 43210" value="<%= typeof formData !== 'undefined' ? formData.phone : '' %>">
              </div>
            </div>
            <div class="col-12">
              <label for="subject" class="form-label">Subject</label>
              <div class="input-group-premium">
                <i class="fas fa-tag"></i>
                <input type="text" class="form-control" id="subject" name="subject" placeholder="What is this regarding?" value="<%= typeof formData !== 'undefined' ? formData.subject : '' %>" required>
                <div class="invalid-feedback">Please specify a subject.</div>
              </div>
            </div>
            <div class="col-12">
              <label for="message" class="form-label">Message</label>
              <textarea class="form-control" id="message" name="message" rows="5" placeholder="Write your message details here..." required><%= typeof formData !== 'undefined' ? formData.message : '' %></textarea>
              <div class="invalid-feedback">Message content is required.</div>
            </div>
            <div class="col-12 mt-4">
              <button type="submit" class="btn btn-success py-2 w-100">Send Message</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Interactive Maps section -->
<div class="row mb-5">
  <div class="col-12">
    <div class="card border-0 shadow-sm overflow-hidden">
      <div class="card-body p-0">
        <div class="ratio ratio-21x9">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14392.836100582236!2d85.14376484391696!3d25.60251761664324!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x39ed58fea5a02c81%3A0x600f6ed6bdc20cc1!2sKankarbagh%2C%20Patna%2C%20Bihar!5e0!3m2!1sen!2sin!4v1719120778521!5m2!1sen!2sin" allowfullscreen="" loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>