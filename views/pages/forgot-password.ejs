<%- include('../partials/header') %>

<div class="row min-vh-75 align-items-center justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card border-0 shadow-sm p-4">
      <div class="card-body">
        
        <div class="text-center mb-4">
          <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 72px; height: 72px; background-color: var(--primary-subtle) !important;">
            <i class="fas fa-key fa-2x text-primary"></i>
          </div>
          <h1 class="h3 fw-bold mb-2">Forgot Password</h1>
          <p class="text-muted small">Enter your email address below and we'll send you a link to reset your password.</p>
        </div>
        
        <form action="/forgot-password" method="POST" class="needs-validation" novalidate>
          
          <div class="mb-4">
            <label for="email" class="form-label">Email Address</label>
            <div class="input-group-premium">
              <i class="fas fa-envelope"></i>
              <input type="email" class="form-control" id="email" name="email" placeholder="name@domain.com" required>
              <div class="invalid-feedback">
                Please provide a valid email address.
              </div>
            </div>
          </div>
          
          <div class="d-grid mb-3">
            <button type="submit" class="btn btn-success py-2">Reset Password</button>
          </div>
          
          <div class="text-center mt-3">
            <a href="/login" class="text-success text-decoration-none small fw-bold"><i class="fas fa-arrow-left me-1"></i> Back to Sign In</a>
          </div>
          
        </form>
        
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>