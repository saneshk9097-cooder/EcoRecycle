<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script>
    (function() {
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme) {
        document.documentElement.setAttribute('data-theme', savedTheme);
      } else {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
      }
    })();
  </script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <nav class="navbar navbar-expand-lg navbar-light fixed-top shadow-sm">
      <div class="container">
        <a class="navbar-brand" href="/">
          <i class="fas fa-recycle me-2"></i>EcoRecycle
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/">Home</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle <%= path.startsWith('/recycling') ? 'active' : '' %>" href="#" id="recyclingDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Recycling
              </a>
              <ul class="dropdown-menu border-0" aria-labelledby="recyclingDropdown">
                <li><a class="dropdown-item" href="/recycling">Overview</a></li>
                <li><a class="dropdown-item" href="/recycling/centers">Recycling Centers</a></li>
                <li><a class="dropdown-item" href="/recycling/pickup">Schedule Pickup</a></li>
              </ul>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle <%= path.startsWith('/education') ? 'active' : '' %>" href="#" id="educationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Education
              </a>
              <ul class="dropdown-menu border-0" aria-labelledby="educationDropdown">
                <li><a class="dropdown-item" href="/education">Overview</a></li>
                <li><a class="dropdown-item" href="/education/facts">E-Waste Facts</a></li>
                <li><a class="dropdown-item" href="/education/tips">Reduction Tips</a></li>
                <li><a class="dropdown-item" href="/education/resources">Resources</a></li>
              </ul>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= path === '/articles' ? 'active' : '' %>" href="/articles">Articles</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= path === '/videos' ? 'active' : '' %>" href="/videos">Videos</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= path === '/reviews' ? 'active' : '' %>" href="/reviews">Reviews</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= path === '/about' ? 'active' : '' %>" href="/about">About</a>
            </li>
            <li class="nav-item">
              <a class="nav-link <%= path === '/contact' ? 'active' : '' %>" href="/contact">Contact</a>
            </li>
          </ul>
          
          <ul class="navbar-nav align-items-center">
            <li class="nav-item me-lg-3 my-2 my-lg-0">
              <button id="theme-toggle" class="btn btn-link nav-link p-2 border-0" aria-label="Toggle Theme" style="background: transparent; cursor: pointer; color: var(--dark-subtle) !important;">
                <i class="fas fa-moon fs-5" id="theme-toggle-dark-icon"></i>
                <i class="fas fa-sun fs-5" id="theme-toggle-light-icon" style="display: none;"></i>
              </button>
            </li>
            <% if (typeof user !== 'undefined' && user) { %>
              <li class="nav-item dropdown ms-lg-2">
                <a class="nav-link dropdown-toggle d-flex align-items-center p-1" href="#" id="userProfileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: var(--radius-xl); outline: none;">
                  <div class="user-avatar-initials d-flex align-items-center justify-content-center text-white fw-bold me-2 shadow-sm" style="width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%); font-size: 0.875rem;">
                    <%= (user.firstName.charAt(0) + user.lastName.charAt(0)).toUpperCase() %>
                  </div>
                  <span class="d-none d-lg-inline text-muted me-1" style="font-weight: 600;"><%= user.firstName %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 mt-2" aria-labelledby="userProfileDropdown" style="min-width: 220px;">
                  <li class="dropdown-header py-2 px-3 border-bottom mb-2">
                    <div class="fw-bold text-dark-subtle" style="color: var(--text-color) !important;"><%= user.firstName %> <%= user.lastName %></div>
                    <div class="small text-muted text-truncate" style="max-width: 170px;"><%= user.email %></div>
                  </li>
                  <li>
                    <a class="dropdown-item py-2 d-flex align-items-center" href="/dashboard">
                      <i class="fas fa-chart-line me-2 text-success" style="width: 16px;"></i>Dashboard
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item py-2 d-flex align-items-center" href="/dashboard">
                      <i class="fas fa-user me-2 text-success" style="width: 16px;"></i>Profile
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item py-2 d-flex align-items-center" href="/dashboard">
                      <i class="fas fa-cog me-2 text-success" style="width: 16px;"></i>Settings
                    </a>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <a class="dropdown-item py-2 text-danger btn-logout-trigger d-flex align-items-center" href="#">
                      <i class="fas fa-sign-out-alt me-2" style="width: 16px;"></i>Logout
                    </a>
                  </li>
                </ul>
              </li>
            <% } else { %>
              <li class="nav-item">
                <a class="nav-link d-flex align-items-center <%= path === '/login' ? 'active' : '' %>" href="/login" style="font-weight: 600;">
                  <i class="fas fa-sign-in-alt me-2"></i>Login
                </a>
              </li>
              <li class="nav-item ms-lg-3">
                <a class="btn btn-success text-white d-flex align-items-center px-4 py-2 mt-2 mt-lg-0 shadow-sm" href="/register" style="font-size: 0.875rem; font-weight: 600; border-radius: var(--radius-sm);">
                  <i class="fas fa-user-plus me-2"></i>Register
                </a>
              </li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>
  </header>
  <!-- Spacer to prevent content from hiding under fixed navbar -->
  <div style="height: 85px;"></div>
  <main class="container py-4">
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 py-3 px-4 fade-in" role="alert">
        <i class="fas fa-check-circle me-2 text-success"></i> <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 py-3 px-4 fade-in" role="alert">
        <i class="fas fa-exclamation-circle me-2 text-danger"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>